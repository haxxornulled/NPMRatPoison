{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] ({TraceId}:{SpanId}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "FallbackConsole": {
      "Enabled": true,
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] ({TraceId}:{SpanId}) {Message:lj}{NewLine}{Exception}"
    },
    "OpenTelemetry": {
      "Enabled": true,
      "Endpoint": "http://localhost:4318",
      "Protocol": "HttpProtobuf"
    }
  },
  "OpenTelemetry": {
    "Console": {
      "Enabled": true
    },
    "Otlp": {
      "Endpoint": "http://localhost:4318"
    }
  },
  "ConnectionStrings": {
    "ProviderIngress": "Host=localhost;Port=5432;Database=npmratpoison;Username=npmratpoison;Password=change-me-before-production"
  },
  "ProviderIngress": {
    "Enabled": true,
    "DatabaseProvider": "postgres",
    "AutoInitializeDatabase": true,
    "MaxPayloadBytes": 262144,
    "AllowedClockSkewMinutes": 10,
    "RequestsPerMinute": 30,
    "ReplayCacheMinutes": 30,
    "Providers": {
      "demo-provider": {
        "Enabled": true,
        "DisplayName": "Demo Provider",
        "Contact": "security@example.invalid",
        "AllowedDocumentTypes": [
          "vulnerability-advisory",
          "indicator-bundle",
          "patch-bundle",
          "catalog-delta"
        ]
      }
    }
  }
}
